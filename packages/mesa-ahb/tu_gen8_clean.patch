+        sysmem_per_ccu_color_cache_size = 32 * 1024,
+        sysmem_ccu_depth_cache_fraction = CCUColorCacheFraction.THREE_QUARTER.value,
+        sysmem_per_ccu_depth_cache_size = 32 * 1024,
+        gmem_vpc_attr_buf_size = 49152,
