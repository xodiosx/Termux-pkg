From ae4012522db5203fd4fb730ef2fdbe6824b9830c Mon Sep 17 00:00:00 2001
From: whitebelyash <whbexiumwork@gmail.com>
Date: Mon, 2 Mar 2026 13:33:03 +0400
Subject: [PATCH 09/10] freedreno/gmem: do not apply gmem cache offset

Causes assertion on A8XX GPUs with lower cache size (2MB>). Needs
investigating.

Signed-off-by: whitebelyash <whbexiumwork@gmail.com>
---
 src/freedreno/common/fd6_gmem_cache.h | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/src/freedreno/common/fd6_gmem_cache.h b/src/freedreno/common/fd6_gmem_cache.h
index c2243d3cb25..b5930309967 100644
--- a/src/freedreno/common/fd6_gmem_cache.h
+++ b/src/freedreno/common/fd6_gmem_cache.h
@@ -43,9 +43,10 @@ __calc_gmem_cache_offsets(const struct fd_dev_info *info, unsigned offset,
    unsigned num_ccu = info->num_ccu;
 
    /* This seems not to be load bearing, but keeping it for now to match blob: */
-   if (info->chip >= 8)
+   /* @todo: re-enable */
+   /*if (info->chip >= 8)
       offset -= 0x78000;
-
+   */
    config->vpc_bv_pos_buf_offset = offset - (num_ccu * config->vpc_bv_pos_buf_size);
    offset = config->vpc_bv_pos_buf_offset;
 
-- 
2.53.0


